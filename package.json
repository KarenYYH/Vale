{
  "name": "vale-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Vale — AI-native knowledge management protocol layer",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"packages/**/*.ts\"",
    "typecheck": "turbo run typecheck",
    "release": "pnpm build && pnpm test && pnpm publish -r --filter='./packages/*'"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  }
}
